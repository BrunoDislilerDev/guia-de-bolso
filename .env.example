# Copie para .env.local e preencha. Na Vercel, use os MESMOS nomes (prefixo NEXT_PUBLIC_).

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
# Chave anon ou publishable (Settings → API Keys no Supabase) — NÃO use service_role aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Opcional — local: http://localhost:3000 · produção: https://guiadebolso.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_OPENWEATHER_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Cron Vercel — purge de locais inativos (30 dias). Gere um valor aleatório longo.
CRON_SECRET=
